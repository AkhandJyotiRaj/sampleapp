<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - Shopping Store</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <h1 class="logo">ShopHub</h1>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/cart" class="cart-link">🛒 Cart</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Back to Home</a>
    
    <section class="product-detail">
      <div class="product-image-large">
        <img src="https://via.placeholder.com/400?text=<%= product.name %>" alt="<%= product.name %>">
      </div>
      
      <div class="product-details-content">
        <h1><%= product.name %></h1>
        <p class="product-description"><%= product.description %></p>
        
        <div class="price-section">
          <p class="price-large">$<%= product.price.toFixed(2) %></p>
          <p class="in-stock">✓ In Stock</p>
        </div>

        <div class="quantity-section">
          <label for="quantity">Quantity:</label>
          <input type="number" id="quantity" min="1" value="1">
        </div>

        <button class="btn btn-primary btn-large" onclick="addToCartFromDetail(<%= product.id %>, '<%= product.name %>')">Add to Cart</button>
        
        <div class="product-specs">
          <h3>Details</h3>
          <ul>
            <li>Product ID: <%= product.id %></li>
            <li>Category: Electronics</li>
            <li>Free Shipping Available</li>
            <li>30-Day Money Back Guarantee</li>
          </ul>
        </div>
      </div>
    </section>
  </div>

  <footer class="footer">
    <p>&copy; 2024 ShopHub. All rights reserved.</p>
  </footer>

  <script>
    function addToCartFromDetail(productId, productName) {
      const quantity = document.getElementById('quantity').value;
      fetch('/add-to-cart', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId, quantity: parseInt(quantity) })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert(productName + ' added to cart!');
        }
      })
      .catch(err => console.error('Error:', err));
    }
  </script>
</body>
</html>
