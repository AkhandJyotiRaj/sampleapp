<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart - Shopping Store</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <h1 class="logo">ShopHub</h1>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/cart" class="cart-link">🛒 Cart</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Continue Shopping</a>
    
    <h1>Shopping Cart</h1>

    <% if (cart.length === 0) { %>
      <div class="empty-cart">
        <p>Your cart is empty</p>
        <a href="/" class="btn btn-primary">Start Shopping</a>
      </div>
    <% } else { %>
      <div class="cart-content">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Total</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach(item => { %>
              <tr id="item-<%= item.id %>">
                <td><%= item.name %></td>
                <td>$<%= item.price.toFixed(2) %></td>
                <td>
                  <input type="number" min="1" value="<%= item.quantity %>" 
                    onchange="updateQuantity(<%= item.id %>, this.value)">
                </td>
                <td>$<%= (item.price * item.quantity).toFixed(2) %></td>
                <td>
                  <button class="btn btn-danger" onclick="removeFromCart(<%= item.id %>)">Remove</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>

        <div class="cart-summary">
          <div class="summary-item">
            <span>Subtotal:</span>
            <span>$<%= total %></span>
          </div>
          <div class="summary-item">
            <span>Shipping:</span>
            <span>FREE</span>
          </div>
          <div class="summary-total">
            <span>Total:</span>
            <span>$<%= total %></span>
          </div>
          <a href="/checkout" class="btn btn-primary btn-large">Proceed to Checkout</a>
        </div>
      </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>&copy; 2024 ShopHub. All rights reserved.</p>
  </footer>

  <script>
    function removeFromCart(productId) {
      if (confirm('Remove this item from cart?')) {
        fetch('/remove-from-cart', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ productId })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            location.reload();
          }
        })
        .catch(err => console.error('Error:', err));
      }
    }

    function updateQuantity(productId, quantity) {
      fetch('/update-quantity', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId, quantity })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          location.reload();
        }
      })
      .catch(err => console.error('Error:', err));
    }
  </script>
</body>
</html>
